{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://webpki.systematicreasoning.com/schema.json","title":"WebPKI Observatory Snapshot","description":"Complete analytical dataset of the Certificate Authority trust ecosystem. ~66K tokens. Designed for LLM consumption, programmatic analysis, and dashboard rendering.","type":"object","required":["$schema","version","generatedAt","market","concentration","trustSurface","geography","governmentRisk","jurisdictionRisk","incidents","distrustEvents","governance","browserCoverage","rootAlgorithms","cryptoSummary","brThresholds","distrustStats"],"properties":{"$schema":{"type":"string","const":"https://webpki.systematicreasoning.com/schema.json"},"version":{"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},"generatedAt":{"type":"string","format":"date-time"},"snapshotUrl":{"type":"string","format":"uri"},"dataSources":{"type":"object"},"browserCoverage":{"type":"object","required":["chrome","apple","mozilla","microsoft"],"properties":{"chrome":{"type":"number"},"apple":{"type":"number"},"mozilla":{"type":"number"},"microsoft":{"type":"number"}}},"market":{"type":"array","description":"Per-CA records for all trusted CAs, sorted by rank","items":{"type":"object","required":["rank","id","caOwner","certs","share","storeCount","trustedBy"]}},"concentration":{"type":"object","required":["hhi","cr3","headCount","tailCount"]},"trustSurface":{"type":"object","required":["totalRoots","totalOwners","perStore"]},"geography":{"type":"array"},"governmentRisk":{"type":"object","required":["total","cas"]},"jurisdictionRisk":{"type":"array","items":{"type":"object","required":["country","risk","axes"]}},"incidents":{"type":"object","required":["total","years","perCA","classification","yearsByClass","fingerprints","categories"]},"brThresholds":{"type":"array"},"cryptoSummary":{"type":"object","required":["totalRoots","keyFamilies","keySizes","sigHashes"]},"rootAlgorithms":{"type":"array","description":"Per-root with algorithm, store, capability, and validity data","items":{"type":"object","required":["name","caOwner","keyFamily","keyBits","sigHash","stores","validTo","tls"]}},"distrustEvents":{"type":"array","items":{"type":"object","required":["ca","year","compliancePosture"]}},"distrustStats":{"type":"object","required":["totalEvents","postureDistribution"]},"governance":{"type":"object","required":["reportCard","meta"],"description":"Full governance data including report card, oversight, enforcement, policy leadership, ballot classification, notable gaps, and inclusion velocity"}}}
